# Optional: used by the chanl CLI when ~/.chanl/config.json does not set these.
# Copy to .env in the repo root or any cwd from which you run `chanl`.
# Load order: dotenv (this file) is read when the CLI starts; config.json still wins if set.

CHANL_SERVER_URL=http://localhost:18005
CHANL_API_KEY=

# Server (packages/server): set to true to require X-API-Key on all routes (default is open).
# CHANL_EVAL_REQUIRE_API_KEY=

# Agent under test (scenario runs)
CHANL_OPENAI_API_KEY=
CHANL_ANTHROPIC_API_KEY=
