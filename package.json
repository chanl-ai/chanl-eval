{
  "name": "chanl-eval",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source AI agent testing and evaluation engine",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chanl-ai/chanl-eval.git"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:cov": "pnpm -r test:cov",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "dev:server": "pnpm --filter @chanl/eval-server start:dev",
    "dev:dashboard": "pnpm --filter @chanl/eval-dashboard dev"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
