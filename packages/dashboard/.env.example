# Copy to .env.local and fill in (Next.js loads .env.local automatically in dev).
# Never commit real keys.

NEXT_PUBLIC_CHANL_EVAL_SERVER=http://localhost:18005
# Only if the server sets CHANL_EVAL_REQUIRE_API_KEY=true (otherwise leave empty).
NEXT_PUBLIC_CHANL_EVAL_API_KEY=

# Optional: for “Run scenario” in the UI (OpenAI or Anthropic key for the agent under test).
NEXT_PUBLIC_CHANL_EVAL_AGENT_API_KEY=
